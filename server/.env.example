# Claude API Key (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI Embedding API Key (required for RAG vector search)
# Used to create query/chunk embeddings for pgvector retrieval
OPENAI_API_KEY=your_openai_api_key_here

# Optional embedding model override (default: text-embedding-3-small)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Server Port (default: 3001)
PORT=3001

# CORS Origin (use * for development, specific domain for production)
CORS_ORIGIN=*
